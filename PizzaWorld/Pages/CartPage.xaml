<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:PizzaWorld.MVVM.ViewModels"
             xmlns:models="clr-namespace:PizzaWorld.MVVM.Models"
             x:Class="PizzaWorld.Pages.CartPage"
             Title="Cart"
             x:DataType="vm:CartViewModel">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Clear Cart"
                     Command="{Binding ClearCartCommand}"/>
    </ContentPage.ToolbarItems>
    <Grid Padding="10">

        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="StartAndExpand">
                    <BoxView HeightRequest="100"
                             Color="white"/>
                    <Label Text="No items in the cart..."
                           FontSize="25"
                           TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
                    <Button Text="Explore all pizzas"
                            Clicked="Button_Clicked"
                            HorizontalOptions="Center"
                            BackgroundColor="Olive"/>


                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Pizza">
                    <Border StrokeShape="RoundRectangle 25"
                            Padding="15"
                            BackgroundColor="#FFB2D286"
                            StrokeThickness="0">
                        <Grid ColumnDefinitions="25, Auto, 50, *, 80, 25">
                            <Label Grid.Column="0"
                                   Text="{Binding CartQuantity}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="x"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                            <Image Grid.Column="2"
                                   Source="{Binding Image}"
                                   WidthRequest="25"
                                   HeightRequest="25"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="3"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Name}"/>
                                <Label Text="{Binding Price, StringFormat='${0}'}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="4"
                                   Text="{Binding Amount,StringFormat='${0:N2}'}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                            <Image Grid.Column="5"
                                   Source="recycle_bin.png"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="Red"/>
                                </Image.Behaviors>
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:CartViewModel}},Path=RemoveCartItemCommand}"
                                                          CommandParameter="{Binding Name}"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>


        <Border StrokeShape="RoundRectangle 40"
                BackgroundColor="DarkGreen"
                StrokeThickness="0"
                VerticalOptions="End"
                Margin="5"
                Padding="10">
            <Grid ColumnDefinitions="*, *">
                <Label Grid.Column="0"
                       Padding="18, 0"
                       TextColor="White">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Total: &#10;"
                                  FontSize="20"/>
                            <Span Text="{Binding TotalAmount, StringFormat='${0:N2}'}"
                                  FontSize="23"
                                  FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Button Grid.Column="1"
                        CornerRadius="22"
                        VerticalOptions="Center"
                        HorizontalOptions="End"
                        Text="Place Order"
                        Command="{Binding PlaceOrderCommand}"
                        Padding="25, 10"
                        BackgroundColor="#FFB2D286"/>
            </Grid>
        </Border>
    </Grid>

</ContentPage>